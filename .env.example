TMDB_API_KEY=your_tmdb_api_key_here

# Xtream account (auto-provisioned at startup)
XTREAM_BASE_URL=http://your-xtream-server.com
XTREAM_PORT=80
XTREAM_USERNAME=your_username
XTREAM_PASSWORD=your_password

SYNC_INTERVAL_HOURS=6
ENRICHMENT_DAILY_LIMIT=50000
HEALTH_CHECK_BATCH_SIZE=1000

# Stream Validation
STREAM_VALIDATION_ENABLED=true
STREAM_VALIDATION_CONCURRENCY=20
STREAM_VALIDATION_TIMEOUT=15
STREAM_BROKEN_THRESHOLD=3
STREAM_VALIDATION_RECHECK_HOURS=24
STREAM_FILTER_BROKEN=true

# Required for Plex library generation (no default - must be set explicitly)
# PLEX_LIBRARY_DIR=/path/to/plex/media

# DB backups (online sqlite snapshots, daily cron)
BACKUP_ENABLED=true
BACKUP_DIR=./data/backups
BACKUP_RETENTION_DAYS=7
BACKUP_HOUR=4
