# ============================================================================
# PlexHub Backend — modèle de configuration
# ----------------------------------------------------------------------------
# Copier ce fichier en `.env` (gitignoré) puis renseigner les valeurs.
# NE JAMAIS commiter de secret réel ici : `.env.example` est suivi par git.
# Les valeurs ci-dessous sont les DÉFAUTS du code (app/config.py) ; ne décommenter
# que ce que tu veux surcharger. Les clés marquées « REQUIS » n'ont pas de défaut.
# ============================================================================

# --- TMDB (enrichissement métadonnées) -------------------------------------
# REQUIS pour l'enrichissement (sinon désactivé). Clé v3 TMDB.
TMDB_API_KEY=
# Locale des requêtes TMDB.
TMDB_LANGUAGE=fr-FR

# --- Authentification API / IA ---------------------------------------------
# REQUIS pour /api/ai (header X-API-Key) et POST /api/tv-auth/approve.
# Sert aussi à dériver la clé Fernet TV si TV_AUTH_ENCRYPTION_KEY est vide.
AI_API_KEY=

# --- Embeddings (recommandations vectorielles) -----------------------------
# Surcharge du modèle fastembed (défaut interne : paraphrase-multilingual-MiniLM-L12-v2).
# AI_EMBED_MODEL=
# Répertoire de cache persistant des poids ONNX (évite le re-téléchargement au cold start).
# AI_EMBED_CACHE_DIR=

# --- Ollama LLM (gemma4 — présentations / chat / sous-titres) ---------------
# Hôte Docker par défaut ; en dev local hors compose, pointer vers ton Ollama.
OLLAMA_URL=http://khoj-ollama:11434
OLLAMA_MODEL=gemma4:e4b

# --- Traduction IA de sous-titres ------------------------------------------
SUBTITLE_CHUNK_CUES=20          # cues SRT envoyées par appel LLM
SUBTITLE_CONCURRENCY=4          # appels de traduction concurrents max
SUBTITLE_MAX_CUES=3000          # au-delà → 413 (un long film ≈ 2500 cues)
SUBTITLE_MAX_BYTES=2000000      # au-delà (~2 Mo) → 413
SUBTITLE_PER_CHUNK_TIMEOUT=120  # timeout LLM par chunk (s)
SUBTITLE_TOTAL_TIMEOUT=600      # deadline requête entière (s) ; dépassé → 503
SUBTITLE_CACHE_RETENTION_DAYS=30  # purge des traductions plus vieilles que N jours (0 = jamais)

# --- Appairage TV (device-flow, /api/tv-auth/*) ----------------------------
# Clé Fernet optionnelle (urlsafe base64, 32 octets) pour chiffrer le payload au repos.
# Si vide, dérivée de AI_API_KEY. Si les deux sont vides → tv-auth renvoie 503.
# Générer : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# TV_AUTH_ENCRYPTION_KEY=
# TV_AUTH_TTL_SECONDS=900         # durée de vie d'une session d'appairage (s)

# --- Compte Xtream (auto-provisionné au démarrage si les 3 champs sont remplis) ---
XTREAM_BASE_URL=
XTREAM_PORT=80
XTREAM_USERNAME=
XTREAM_PASSWORD=

# --- Chiffrement au repos des mots de passe Xtream (CR-S03) -----------------
# Clé Fernet dédiée (urlsafe base64, 32 octets) RECOMMANDÉE en prod.
# Si vide, dérivée de AI_API_KEY (dérivation différente de TV_AUTH_ENCRYPTION_KEY,
# donc pas la même clé). Si les deux (celle-ci et AI_API_KEY) sont vides, les
# mots de passe Xtream restent en CLAIR (fail-open, ne bloque pas la sync) —
# renseigner l'une des deux clés pour activer le chiffrement.
# ⚠️ Si cette clé change après coup sans ré-exécuter la migration 016 sur les
# lignes déjà chiffrées, les mots de passe existants deviennent indéchiffrables.
# Générer : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# XTREAM_ENCRYPTION_KEY=

# --- Répertoires données / logs --------------------------------------------
DATA_DIR=./data
LOG_DIR=./logs

# --- Synchronisation & enrichissement --------------------------------------
SYNC_INTERVAL_HOURS=6
ENRICHMENT_DAILY_LIMIT=50000
HEALTH_CHECK_BATCH_SIZE=1000

# --- Validation des flux ----------------------------------------------------
STREAM_VALIDATION_ENABLED=true
STREAM_VALIDATION_CONCURRENCY=20
STREAM_VALIDATION_TIMEOUT=15
STREAM_BROKEN_THRESHOLD=3
STREAM_VALIDATION_RECHECK_HOURS=24
STREAM_FILTER_BROKEN=true

# --- Sauvegardes DB (snapshots SQLite, cron quotidien) ---------------------
BACKUP_ENABLED=true
BACKUP_DIR=./data/backups
BACKUP_RETENTION_DAYS=7
BACKUP_HOUR=4                   # heure (0-23) du cron de backup

# --- CORS -------------------------------------------------------------------
# Défaut `*` (ouvert) — RESTREINDRE en prod (liste séparée par des virgules).
CORS_ORIGINS=*

# --- Génération bibliothèque Plex/Jellyfin ---------------------------------
# Pas de défaut : à définir explicitement pour activer la génération auto au boot
# (en bare-metal / uvicorn). En Docker, voir PLEX_MEDIA_HOST_PATH ci-dessous.
# PLEX_LIBRARY_DIR=/path/to/plex/media

# --- Téléchargement physique de médias (onglet admin « Télécharger ») -------
# Dossier DÉDIÉ où les vrais fichiers vidéo sont téléchargés (≠ PLEX_LIBRARY_DIR,
# qui ne contient que des .strm de référence). TANT QUE VIDE, la feature est
# INACTIVE (le worker de drain est un no-op) : à définir pour l'activer.
# DOWNLOAD_DIR=/path/to/downloads
# Nombre de téléchargements simultanés drainés par le worker (master-only).
DOWNLOAD_CONCURRENCY=1
# Taille des chunks de streaming httpx (octets).
DOWNLOAD_CHUNK_BYTES=1048576
# Tentatives automatiques sur erreur transitoire avant d'échouer le job.
DOWNLOAD_MAX_RETRIES=3
# Préflight espace disque : refuse de démarrer un job si l'espace libre sous
# DOWNLOAD_DIR est inférieur à ce seuil (Mo). <=0 = désactivé.
DOWNLOAD_MIN_FREE_DISK_MB=2048
# Intervalle de polling de la file par le worker (secondes).
DOWNLOAD_POLL_INTERVAL=2
# Timeouts httpx du téléchargement (secondes) : connexion / lecture de chunk.
DOWNLOAD_CONNECT_TIMEOUT=30
DOWNLOAD_READ_TIMEOUT=120

# ============================================================================
# Variables lues UNIQUEMENT par docker-compose.yml (pas par l'app Python)
# ============================================================================
# Port exposé du conteneur (et utilisé par le healthcheck).
APP_PORT=8000
# Fuseau horaire du conteneur.
TZ=UTC
# Chemin HÔTE monté sur /app/media (= PLEX_LIBRARY_DIR dans le conteneur).
PLEX_MEDIA_HOST_PATH=./media

# --- Cloudflare Tunnel ------------------------------------------------------
# Jeton fourni par le tableau de bord Cloudflare (Zero Trust) pour exposer l'app
# sans ouvrir de ports.
# CLOUDFLARE_TUNNEL_TOKEN=ey...
