TMDB_API_KEY=your_tmdb_api_key_here

# Xtream account (auto-provisioned at startup)
XTREAM_BASE_URL=http://your-xtream-server.com
XTREAM_PORT=80
XTREAM_USERNAME=your_username
XTREAM_PASSWORD=your_password

SYNC_INTERVAL_HOURS=6
ENRICHMENT_DAILY_LIMIT=50000
HEALTH_CHECK_BATCH_SIZE=1000

# Stream Validation
STREAM_VALIDATION_ENABLED=true
STREAM_VALIDATION_CONCURRENCY=20
STREAM_VALIDATION_TIMEOUT=15
STREAM_BROKEN_THRESHOLD=3
STREAM_VALIDATION_RECHECK_HOURS=24
STREAM_FILTER_BROKEN=true

# Required for Plex library generation (no default - must be set explicitly)
# PLEX_LIBRARY_DIR=/path/to/plex/media

# TV pairing (device-flow, /api/tv-auth/*)
# Optional explicit Fernet key for payload encryption at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# When unset, a key is derived from AI_API_KEY. When neither is set,
# tv-auth endpoints return 503.
# TV_AUTH_ENCRYPTION_KEY=
# TV_AUTH_TTL_SECONDS=900

# DB backups (online sqlite snapshots, daily cron)
BACKUP_ENABLED=true
BACKUP_DIR=./data/backups
BACKUP_RETENTION_DAYS=7
BACKUP_HOUR=4

# --- AI subtitle translation ---
SUBTITLE_CHUNK_CUES=20        # number of SRT cues sent per LLM call
SUBTITLE_CONCURRENCY=4        # max concurrent LLM translation calls
SUBTITLE_MAX_CUES=3000        # reject subtitle files with more cues than this (→ 413); long film ≈ 2500 cues
SUBTITLE_MAX_BYTES=2000000    # reject subtitle files larger than ~2 MB (→ 413)
SUBTITLE_PER_CHUNK_TIMEOUT=120  # per-chunk LLM timeout in seconds
SUBTITLE_TOTAL_TIMEOUT=600    # whole-request deadline in seconds; exceeded → 503
